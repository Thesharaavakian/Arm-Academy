DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave empty for SQLite in dev; set postgres URL for production
DATABASE_URL=
# DATABASE_URL=postgresql://arm_user:arm_password@db:5432/arm_academy

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=arm_academy
POSTGRES_USER=arm_user
POSTGRES_PASSWORD=arm_password

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@armacademy.am

# AWS S3 (optional — for video storage in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
