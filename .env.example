# ─────────────────────────────────────────────────────────────────────────────
# Arm Academy — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# For production:
# ALLOWED_HOSTS=armacademy.am,www.armacademy.am,13.61.77.153

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty for SQLite (dev only); required in production
DATABASE_URL=
# DATABASE_URL=postgresql://arm_user:arm_password@db:5432/arm_academy

# PostgreSQL credentials (used by docker-compose db service)
POSTGRES_DB=arm_academy
POSTGRES_USER=arm_user
POSTGRES_PASSWORD=arm_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Docker: REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser requests
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Production: CORS_ALLOWED_ORIGINS=https://armacademy.am,https://www.armacademy.am

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://armacademy.am

# ── Email — Brevo SMTP ────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@armacademy.am

# ── SMS — Zadarma ─────────────────────────────────────────────────────────────
ZADARMA_API_KEY=
ZADARMA_API_SECRET=

# ── Payments — Stripe (test mode) ─────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Listen locally: stripe listen --forward-to localhost:8000/api/payments/webhook/
# Test card: 4242 4242 4242 4242  exp 12/34  cvv 123

# ── Celery ────────────────────────────────────────────────────────────────────
# Set True in dev to run tasks inline (no Redis/Celery worker needed)
CELERY_ALWAYS_EAGER=True
# Production: CELERY_ALWAYS_EAGER=False

# ── Docker Compose ────────────────────────────────────────────────────────────
# External port for the nginx container (default 8080 — avoids conflict with
# existing services on port 80)
EXTERNAL_PORT=8080

# ── AWS S3 (optional — for video file storage in production) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-north-1
